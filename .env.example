# Cloudflare R2 credentials for video upload (Phase 2).
# Copy this file to ".env" and fill in your values. ".env" is gitignored.
#
#   cp .env.example .env
#
# Where to find these:
# - R2_ACCOUNT_ID:        Cloudflare dashboard → R2 overview, "Account ID"
# - R2_ACCESS_KEY_ID:     R2 → Manage R2 API Tokens → create Account API token
#                         (Object Read & Write) → "Access Key ID"
# - R2_SECRET_ACCESS_KEY: same token → "Secret Access Key" (shown once)
# - R2_BUCKET:            your bucket name
# - R2_PUBLIC_BASE:       the bucket's public r2.dev URL (or custom domain later)

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=zerbnet-media
R2_PUBLIC_BASE=https://pub-a0c77317c3024e5db24448b1f68cdada.r2.dev


# ── AI "Ask" assistant (Phase 4) ───────────────────────────────────────────
# Multi-provider: fill at least one key. AI_PROVIDER=auto uses the first present
# in this order: gemini → openai → anthropic.
AI_PROVIDER=auto

# Google Gemini (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional fallbacks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Constraints (keep usage free + prevent abuse)
AI_MODEL=gemini-2.5-flash
AI_MAX_OUTPUT_TOKENS=600       # cap answer length
AI_MAX_INPUT_CHARS=500         # cap a single question
AI_RATE_LIMIT_PER_MIN=5        # per visitor IP (under gemini-2.5-flash free ~10 RPM)
AI_RATE_LIMIT_PER_DAY=30       # per visitor IP
AI_DAILY_GLOBAL_CAP=200        # site-wide/day — keep UNDER your free RPD (2.5-flash ~250).
                               # Check your exact RPD in AI Studio → "view rate limits".

# ── Rate-limit store (optional but recommended for production) ──────────────
# Without these, the limiter is in-memory only: each serverless instance keeps
# its own counts, so the limits aren't truly enforced across instances. Connect
# a free Upstash Redis (or Vercel KV) and the limits become shared/global.
# Create at https://upstash.com → Redis database → "REST API" tab.
# (Vercel KV's KV_REST_API_URL / KV_REST_API_TOKEN are also picked up.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
