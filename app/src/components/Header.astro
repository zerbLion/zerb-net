---
const links: { label: string; href: string; external?: boolean }[] = [
  { label: 'Motion', href: '/#motion' },
  { label: 'Visual', href: '/#visual' },
  { label: 'Code', href: '/#code' },
  { label: 'Resume', href: '/resume/' },
  { label: 'Blog', href: 'https://zerblion.github.io/zrxl_blog/', external: true },
];
---

<header id="masthead" transition:persist="site-header" class="fixed top-0 left-0 z-50 w-full">
  <div class="mx-auto flex max-w-[1400px] items-center justify-between px-6 py-4 md:px-10">
    <a href="/" data-cursor="Home" class="shrink-0" aria-label="ZERB home">
      <img
        src="/media/images/common/brand/zerb-logo.png"
        alt="ZERB"
        width="672"
        height="546"
        class="h-8 w-auto md:h-10"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="-my-3 hidden items-center gap-4 md:flex font-display">
      {
        links.map((l) => (
          <a
            href={l.href}
            data-cursor={l.external ? 'Link' : 'Go'}
            {...(l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="px-3 py-3 text-sm font-medium uppercase tracking-wide text-mist transition-colors hover:text-paper"
          >
            {l.label}
          </a>
        ))
      }
      <button
        data-ask-ai
        data-cursor="Ask"
        class="rounded-full border border-line px-4 py-1.5 text-sm font-medium uppercase tracking-wide text-paper transition-colors hover:border-accent hover:text-accent"
      >
        AI Ask
      </button>
    </nav>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      class="font-display text-sm font-bold uppercase tracking-wide md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      Menu
    </button>
  </div>
</header>

<!-- Mobile menu — OUTSIDE <header> on purpose: the header's backdrop-filter makes
     it a containing block for fixed children, which would trap this overlay to the
     header's height instead of filling the viewport. (visibility-driven; see
     #mobile-menu in global.css) -->
<nav id="mobile-menu" transition:persist="mobile-menu" class="flex flex-col justify-center gap-6 px-8 font-display md:hidden">
  {
    links.map((l) => (
      <a href={l.href} data-mobile-link {...(l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})} class="text-4xl font-black tracking-tight text-paper">
        {l.label}
      </a>
    ))
  }
  <button
    data-ask-ai
    data-mobile-link
    class="mt-4 w-fit rounded-full border border-line px-6 py-2 text-lg font-bold uppercase tracking-wide text-paper"
  >
    AI Ask
  </button>
</nav>

<script>
  // All handlers use document-level delegation so they keep working across Astro
  // View Transitions (the header is persisted; its inline script runs only once).
  const menu = () => document.getElementById('mobile-menu');
  const toggle = () => document.getElementById('nav-toggle');
  const setMenu = (open: boolean) => {
    const m = menu();
    const t = toggle();
    if (!m) return;
    m.classList.toggle('is-open', open);
    if (t) {
      t.textContent = open ? 'Close' : 'Menu';
      t.setAttribute('aria-expanded', String(open));
    }
    document.documentElement.classList.toggle('overlay-open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  };

  document.addEventListener('click', (e) => {
    const target = e.target as Element;
    if (target.closest('#nav-toggle')) {
      setMenu(!menu()?.classList.contains('is-open'));
      return;
    }
    if (target.closest('[data-ask-ai]')) {
      setMenu(false);
      window.dispatchEvent(new CustomEvent('open-ask-ai'));
      return;
    }
    if (target.closest('[data-mobile-link]')) {
      setMenu(false);
      return;
    }
    // tap the empty backdrop of the open menu to close it
    if (target.closest('#mobile-menu') && !target.closest('a, button')) {
      setMenu(false);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setMenu(false);
  });

  // Always start closed on each page load (and never leave the body locked).
  document.addEventListener('astro:page-load', () => setMenu(false));
</script>
