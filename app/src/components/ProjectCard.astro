---
interface Props {
  href: string;
  title: string;
  cover: string;
  year?: string | number;
  external?: boolean;
  featured?: boolean;
}
const { href, title, cover, year, external, featured = false } = Astro.props;
const isExternal = external ?? href.startsWith('http');
---

<a
  href={href}
  data-cursor={isExternal ? 'Open' : 'View'}
  class="reveal group block"
  {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <div
    class:list={[
      'relative overflow-hidden rounded-xl bg-surface',
      // Featured banner is full-bleed, so on wide screens it gets tall (~470px).
      // Use a wider ratio at lg+ so it's a sleeker ~375px banner (width stays
      // full; object-cover just crops a touch more). Small cards keep 950/320.
      featured ? 'aspect-[950/320] lg:aspect-[1600/430]' : 'aspect-[950/320]',
    ]}
  >
    <img
      src={cover}
      alt={title}
      loading={featured ? 'eager' : 'lazy'}
      class="h-full w-full object-cover transition-transform duration-[900ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/10 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
    >
    </div>
  </div>

  <div class="mt-5 flex items-baseline justify-between gap-4">
    <h3 class="font-display text-lg font-bold transition-colors duration-300 group-hover:text-accent md:text-2xl">
      {title}
    </h3>
    {year && <span class="shrink-0 text-sm text-mist">{year}</span>}
  </div>
</a>
