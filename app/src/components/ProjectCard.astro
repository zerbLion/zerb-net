---
interface Props {
  href: string;
  title: string;
  cover: string;
  year?: string | number;
  external?: boolean;
  featured?: boolean;
}
const { href, title, cover, year, external, featured = false } = Astro.props;
const isExternal = external ?? href.startsWith('http');
---

<a
  href={href}
  data-cursor={isExternal ? 'Open' : 'View'}
  class="reveal group block"
  {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <div class="relative aspect-[950/320] overflow-hidden rounded-xl bg-surface">
    <img
      src={cover}
      alt={title}
      loading={featured ? 'eager' : 'lazy'}
      class="h-full w-full object-cover transition-transform duration-[900ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/10 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
    >
    </div>
  </div>

  <div class="mt-5 flex items-baseline justify-between gap-4">
    <h3
      class:list={[
        'font-display font-bold transition-colors duration-300 group-hover:text-accent',
        featured ? 'text-2xl md:text-4xl' : 'text-lg md:text-2xl',
      ]}
    >
      {title}
    </h3>
    {year && <span class="shrink-0 text-sm text-mist">{year}</span>}
  </div>
</a>
