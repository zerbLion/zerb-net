---
interface Props {
  href: string;
  title: string;
  summary?: string;
  cover: string;
  year?: string | number;
  pillars?: string[];
  external?: boolean;
}
const { href, title, summary, cover, year, pillars = [], external } = Astro.props;
const isExternal = external ?? href.startsWith('http');
---

<a
  href={href}
  class="reveal group block"
  {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <div class="relative aspect-[950/320] overflow-hidden rounded-xl bg-surface">
    <img
      src={cover}
      alt={title}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-[900ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.06]"
    />
    <!-- hover veil -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/10 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
    >
    </div>
    <!-- arrow badge -->
    <div
      class="absolute right-4 top-4 flex h-9 w-9 translate-y-1 items-center justify-center rounded-full bg-paper text-ink opacity-0 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:translate-y-0 group-hover:opacity-100"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        {
          isExternal ? (
            <path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          ) : (
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          )
        }
      </svg>
    </div>
  </div>

  <div class="mt-4 flex items-baseline justify-between gap-4">
    <h3 class="font-display text-xl font-bold transition-colors duration-300 group-hover:text-accent">
      {title}
    </h3>
    {year && <span class="shrink-0 text-sm text-mist">{year}</span>}
  </div>
  {summary && <p class="mt-1 text-sm leading-relaxed text-mist">{summary}</p>}
  {
    pillars.length > 0 && (
      <div class="mt-3 flex gap-2">
        {pillars.map((p) => (
          <span class="rounded-full border border-line px-2.5 py-0.5 text-xs uppercase tracking-wide text-mist">
            {p}
          </span>
        ))}
      </div>
    )
  }
</a>
