---
// Fonts are self-hosted with our own @font-face (font-display: block) in
// global.css, and preloaded below — so the real font shows immediately with no
// fallback flash / weight jump.
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import AskAI from '../components/AskAI.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ZERB LION — Motion · Visual · Code',
  description = 'ZERB LION (zerbLion) — a China-based motion designer & visual artist. Motion, visual art, and living interactive interfaces; proficient in After Effects, Cinema 4D, Octane.',
} = Astro.props;

const SITE = 'https://zerb.net';
const canonical = new URL(Astro.url.pathname, SITE).href;
const ogImage = new URL('/media/images/common/brand/cropped-logo_high2.png', SITE).href;
const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'ZERB LION',
  alternateName: ['ZERB', 'zerbLion', 'ZerbLion', 'Zerb Lion'],
  url: SITE,
  jobTitle: 'Motion Designer & Visual Artist',
  sameAs: [
    'https://github.com/zerbLion',
    'https://x.com/lionzerb',
    'https://zerblion.github.io/zrxl_blog/',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <!--
      ZERB — Motion · Visual · Code  ·  https://zerb.net
      © 2026 ZERB LION. All rights reserved — code and creative work.
      Source-available for reference, NOT open source. Don't copy or republish.
      Designed, written & built by zerbLion — https://github.com/zerbLion
    -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Gate the hero intro: hide intro elements only when JS is present, and
      // force-reveal after a timeout as a failsafe so the headline can NEVER get
      // stuck invisible if the intro script fails to run.
      (function () {
        var d = document.documentElement;
        d.classList.add('js');
        // Always start at the top on (re)load so the header's scrolled-state border
        // never flashes on during scroll restoration.
        try { history.scrollRestoration = 'manual'; } catch (e) {}
        // Only force-reveal if the intro actually failed to finish — otherwise the
        // failsafe's !important rules would keep overriding the live cursor-magnet.
        setTimeout(function () {
          if (!d.classList.contains('intro-ready')) d.classList.add('hero-fallback');
        }, 3500);
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="ZERB LION (zerbLion)" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ZERB LION" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(person)} />
    <link rel="icon" href="/media/images/common/brand/cropped-%E5%A4%B4%E5%83%8F2-1-32x32.webp" sizes="32x32" />
    <link rel="icon" href="/media/images/common/brand/cropped-%E5%A4%B4%E5%83%8F2-1-192x192.webp" sizes="192x192" />
    <link rel="apple-touch-icon" href="/media/images/common/brand/cropped-%E5%A4%B4%E5%83%8F2-1-192x192.webp" />
    <link rel="preload" href="/fonts/montserrat-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/mulish-latin.woff2" as="font" type="font/woff2" crossorigin />
    <noscript>
      <style>.reveal { opacity: 1 !important; transform: none !important; }</style>
    </noscript>
    <ClientRouter />
  </head>
  <body class="bg-ink text-paper">
    <div id="cursor" transition:persist="cursor" aria-hidden="true"><span class="cursor-label"></span></div>
    <Header />
    <slot />
    <AskAI transition:persist="askai" />

    <script>
      import { setupMotion } from '../scripts/motion';
      setupMotion();
    </script>
  </body>
</html>
