---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — ZERB" description="Page not found.">

  <main class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <p class="font-display text-[28vw] font-black leading-none text-surface md:text-[18vw]">404</p>
    <h1 class="-mt-8 font-display text-3xl font-black md:text-5xl">Lost in motion.</h1>
    <p class="mt-4 max-w-md text-mist">This page drifted off. Let's get you back to the work.</p>
    <a
      href="/"
      class="mt-8 rounded-full border border-line px-6 py-2.5 text-sm font-medium uppercase tracking-wide transition-colors hover:border-accent hover:text-accent"
    >
      Back home
    </a>
  </main>
</Layout>
