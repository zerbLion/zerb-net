---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

// Migrated project bodies (raw HTML from the WordPress export).
const bodies = import.meta.glob('../../project-bodies/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

export async function getStaticPaths() {
  const all = (await getCollection('projects'))
    .filter((p) => !p.data.draft && !p.data.externalUrl)
    .sort((a, b) => a.data.order - b.data.order);

  return all.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: all[(i - 1 + all.length) % all.length],
      next: all[(i + 1) % all.length],
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { title, summary, cover, year, role, pillars } = entry.data;

const bodyKey = Object.keys(bodies).find((k) => k.endsWith(`/${entry.id}.html`));
const body = bodyKey ? bodies[bodyKey] : '';
---

<Layout title={`${title} — ZERB`} description={summary}>

  <main class="pt-36 md:pt-44">
    <!-- Hero -->
    <section class="px-6 md:px-10">
      <div class="mx-auto max-w-[1400px]">
        <a href="/#visual" class="text-sm text-mist transition-colors hover:text-paper">← Back to work</a>
        <div class="mt-6 flex flex-wrap items-end justify-between gap-4">
          <h1 class="font-display text-5xl font-black leading-none md:text-8xl">{title}</h1>
          <div class="flex flex-wrap items-center gap-3 text-sm text-mist">
            {year && <span>{year}</span>}
            {role && <span>· {role}</span>}
            {pillars.map((p) => (
              <span class="rounded-full border border-line px-2.5 py-0.5 text-xs uppercase tracking-wide">{p}</span>
            ))}
          </div>
        </div>
        {summary && <p class="mt-6 max-w-2xl text-lg text-mist">{summary}</p>}
        <div class="mt-10 overflow-hidden rounded-2xl">
          <img src={cover} alt={title} class="w-full object-cover" />
        </div>
      </div>
    </section>

    <!-- Migrated body -->
    <article class="entry-content mx-auto max-w-3xl px-6 py-20 md:px-0" set:html={body} />

    <!-- Prev / Next -->
    <nav class="mt-16 border-t border-line">
      <div class="mx-auto grid max-w-[1400px] grid-cols-1 sm:grid-cols-2">
        <a href={`/project/${prev.id}/`} class="group border-b border-line px-6 py-16 sm:border-b-0 sm:border-r md:px-10">
          <span class="text-xs uppercase tracking-widest text-mist">Previous</span>
          <p class="mt-3 font-display text-2xl font-bold transition-colors group-hover:text-accent">{prev.data.title}</p>
        </a>
        <a href={`/project/${next.id}/`} class="group px-6 py-16 sm:text-right md:px-10">
          <span class="text-xs uppercase tracking-widest text-mist">Next</span>
          <p class="mt-3 font-display text-2xl font-bold transition-colors group-hover:text-accent">{next.data.title}</p>
        </a>
      </div>
    </nav>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Styling for migrated WordPress block HTML inside .entry-content */
  .entry-content { font-size: 1.05rem; line-height: 1.9; color: var(--color-paper); }
  .entry-content > * { margin-block: 1.4rem; }
  .entry-content p { color: #d4d4d8; }
  .entry-content a { color: var(--color-accent-soft); text-decoration: underline; text-underline-offset: 3px; }
  .entry-content figure { margin: 2.5rem 0; }
  .entry-content img,
  .entry-content video {
    width: 100%;
    height: auto;
    border-radius: 14px;
    display: block;
  }
  .entry-content figure.is-resized img { width: 100% !important; height: auto !important; }
  .entry-content figcaption {
    margin-top: 0.6rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-mist);
  }
  .entry-content .wp-block-spacer { height: 1.5rem !important; }
</style>
