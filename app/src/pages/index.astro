---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

const all = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

const hrefFor = (p: (typeof all)[number]) =>
  p.data.externalUrl ?? `/project/${p.id}/`;

const pillars = [
  { id: 'motion', label: 'Motion', tagline: 'Systems of movement — interfaces that breathe.' },
  { id: 'visual', label: 'Visual', tagline: 'Worlds, surfaces and light.' },
  { id: 'code', label: 'Code', tagline: 'Things built, not just designed.' },
] as const;

const byPillar = (id: string) => all.filter((p) => p.data.pillars.includes(id as any));
---

<Layout>

  <main>
    <!-- HERO -->
    <section class="relative flex min-h-screen flex-col justify-center px-6 md:px-10">
      <div class="mx-auto w-full max-w-[1400px]" data-hero>
        <h1 class="font-display text-[14vw] font-black leading-[0.85] md:text-[10vw]">
          <span class="hl"><span class="hl-t" data-mask>Motion</span><span class="hero-dot" data-dot="motion" aria-hidden="true"><span class="hero-dot-m"><i class="hero-dot-i"></i></span></span></span><br />
          <span class="hl"><span class="hl-t" data-blur>Visual</span><span class="hero-dot" data-dot="visual" aria-hidden="true"><span class="hero-dot-m"><i class="hero-dot-i"></i></span></span></span><br />
          <span class="hl"><span class="hl-t" data-type>Code</span><span class="hero-dot" data-dot="code" aria-hidden="true"><span class="hero-dot-m"><i class="hero-dot-i"></i></span></span></span>
        </h1>
        <p class="mt-8 max-w-xl text-lg text-mist">
          A motion designer & visual artist crafting living, interactive interfaces.
          Scroll, or just ask the AI anything about my work.
        </p>
      </div>
      <div class="absolute bottom-8 left-6 flex items-center gap-3 text-xs uppercase tracking-[0.25em] text-mist md:left-10">
        <span class="relative block h-10 w-px overflow-hidden bg-line">
          <span class="absolute inset-x-0 top-0 h-4 animate-[scrollcue_1.8s_ease-in-out_infinite] bg-accent"></span>
        </span>
        Scroll
      </div>
    </section>

    <!-- PILLAR SECTIONS -->
    {
      pillars.map((pillar) => {
        const all = byPillar(pillar.id);
        const [featured, ...rest] = all.slice(0, 5); // featured + up to 4
        return (
          <section id={pillar.id} class="border-t border-line px-6 py-28 md:px-10 md:py-40">
            <div class="mx-auto max-w-[1400px]">
              <div class="reveal mb-16 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
                <h2 class="font-display text-6xl font-black md:text-8xl">{pillar.label}</h2>
                <p class="text-mist md:text-right">{pillar.tagline}</p>
              </div>
              {
                featured ? (
                  <div class="space-y-16">
                    <ProjectCard
                      featured
                      href={hrefFor(featured)}
                      title={featured.data.title}
                      cover={featured.data.coverLarge ?? featured.data.cover}
                      year={featured.data.year}
                    />
                    {rest.length > 0 && (
                      <div class="grid grid-cols-1 gap-x-10 gap-y-16 lg:grid-cols-2">
                        {rest.map((p) => (
                          <ProjectCard
                            href={hrefFor(p)}
                            title={p.data.title}
                            cover={p.data.cover}
                            year={p.data.year}
                          />
                        ))}
                      </div>
                    )}
                  </div>
                ) : (
                  <p class="reveal text-mist">More coming soon.</p>
                )
              }
              {featured && (
                <a
                  href={`/works/?f=${pillar.id}`}
                  data-cursor="View"
                  class="reveal group mt-16 inline-flex items-center gap-3 font-display text-lg font-bold transition-colors hover:text-accent"
                >
                  View all work
                  <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
                </a>
              )}
            </div>
          </section>
        );
      })
    }
  </main>

  <Footer />
</Layout>
