---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const all = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

const hrefFor = (p: (typeof all)[number]) =>
  p.data.externalUrl ?? `/project/${p.id}/`;

const filters = ['all', 'motion', 'visual', 'code'] as const;
---

<Layout title="Work — ZERB" description="Selected work by ZERB.">

  <main class="pt-36 md:pt-44">
    <section class="px-6 md:px-10">
      <div class="mx-auto max-w-[1400px]">
        <h1 class="font-display text-6xl font-black md:text-8xl">Work</h1>

        <div class="mt-10 flex flex-wrap gap-2">
          {
            filters.map((f) => (
              <button
                data-filter={f}
                class="filter-btn rounded-full border border-line px-4 py-1.5 text-sm font-medium uppercase tracking-wide text-mist transition-colors hover:text-paper data-[active]:border-accent data-[active]:text-accent"
                data-active={f === 'all' ? '' : undefined}
              >
                {f}
              </button>
            ))
          }
        </div>

        <div id="works-grid" class="mt-12 grid grid-cols-1 gap-x-10 gap-y-16 pb-24 lg:grid-cols-2">
          {
            all.map((p) => (
              <div class="work-item" data-pillars={p.data.pillars.join(' ')}>
                <ProjectCard
                  href={hrefFor(p)}
                  title={p.data.title}
                  cover={p.data.cover}
                  year={p.data.year}
                />
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Runs on every page-load so it works after View-Transition navigation too.
  const setupWorksFilter = () => {
    const grid = document.getElementById('works-grid');
    if (!grid) return; // not on the works page
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.work-item');

    const setItems = (f: string) => {
      items.forEach((it) => {
        const show = f === 'all' || (it.dataset.pillars || '').includes(f);
        it.style.display = show ? '' : 'none';
      });
    };
    // Crossfade the whole grid so the layout reflow happens while it's invisible
    // (no hard per-card cut).
    const apply = (f: string, instant = false) => {
      buttons.forEach((b) => b.toggleAttribute('data-active', b.dataset.filter === f));
      if (instant) {
        setItems(f);
        return;
      }
      grid.style.opacity = '0';
      window.setTimeout(() => {
        setItems(f);
        grid.style.opacity = '1';
      }, 220);
    };

    buttons.forEach((btn) => btn.addEventListener('click', () => apply(btn.dataset.filter!)));

    // Honor a ?f=<pillar> deep link from the homepage "View all work" CTA.
    const f = new URLSearchParams(location.search).get('f');
    apply(f && ['motion', 'visual', 'code'].includes(f) ? f : 'all', true);
  };

  setupWorksFilter();
  document.addEventListener('astro:page-load', setupWorksFilter);
</script>
