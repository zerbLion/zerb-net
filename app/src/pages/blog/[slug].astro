---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const bodies = import.meta.glob('../../migrated/blog-*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { title, date, cover, excerpt } = entry.data;

const bodyKey = Object.keys(bodies).find((k) => k.endsWith(`/blog-${entry.id}.html`));
const body = bodyKey ? bodies[bodyKey] : '';

const fmt = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — ZERB`} description={excerpt}>
  <Header />

  <main class="pt-36 md:pt-44">
    <section class="px-6 md:px-10">
      <div class="mx-auto max-w-3xl">
        <a href="/blog/" class="text-sm text-mist transition-colors hover:text-paper">← All posts</a>
        <p class="mt-6 text-sm text-mist">{fmt}</p>
        <h1 class="mt-2 font-display text-5xl font-black leading-tight md:text-6xl">{title}</h1>
        <div class="mt-10 overflow-hidden rounded-2xl">
          <img src={cover} alt={title} class="w-full object-cover" />
        </div>
        <article class="entry-content mt-12 pb-24" set:html={body} />
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:global>
  .entry-content { font-size: 1.05rem; line-height: 1.9; color: #d4d4d8; }
  .entry-content > * { margin-block: 1.4rem; }
  .entry-content a { color: var(--color-accent-soft); text-decoration: underline; text-underline-offset: 3px; }
  .entry-content figure { margin: 2.5rem 0; }
  .entry-content img, .entry-content video { width: 100%; height: auto; border-radius: 14px; display: block; }
  .entry-content figcaption { margin-top: 0.6rem; text-align: center; font-size: 0.85rem; color: var(--color-mist); }
  .entry-content .wp-block-spacer { height: 1.5rem !important; }
</style>
