---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title="Blog — ZERB" description="Writing by ZERB.">
  <Header />

  <main class="pt-36 md:pt-44">
    <section class="px-6 md:px-10">
      <div class="mx-auto max-w-[1100px]">
        <h1 class="font-display text-6xl font-black md:text-8xl">Blog</h1>

        <div class="mt-14 grid grid-cols-1 gap-x-8 gap-y-14 pb-24 sm:grid-cols-2">
          {
            posts.map((post) => (
              <a href={`/blog/${post.id}/`} class="group block">
                <div class="aspect-[16/10] overflow-hidden rounded-xl bg-surface">
                  <img
                    src={post.data.cover}
                    alt={post.data.title}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
                  />
                </div>
                <p class="mt-4 text-sm text-mist">{fmt(post.data.date)}</p>
                <h2 class="mt-1 font-display text-2xl font-bold transition-colors group-hover:text-accent">
                  {post.data.title}
                </h2>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
